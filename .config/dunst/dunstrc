[global]
    monitor = 0
    follow = mouse
    width = 300
    height = (0, 80)
    origin = top-center
    offset = (30, 30)
    scale = 0
    notification_limit = 5

    # Estética Hacker/Cute
    frame_width = 3
    frame_color = "#ff69b4"
    separator_color = frame
    font = JetBrainsMono Nerd Font 10
    corner_radius = 15
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    highlight = "#ff69b4"

[urgency_low]
    timeout = 2
