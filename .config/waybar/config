{
    "layer": "top",
    "position": "top",
    "height": 40,
    "margin-top": 10,
    "margin-left": 20,
    "margin-right": 20,
    "spacing": 8,

    "modules-left": [
        "custom/icon",  
        "power-profiles-daemon",   // 1. Modo de energía
        "custom/launcher",         // 2. Logo EndeavourOS
        "temperature",             // 3. Temperatura
        "hyprland/workspaces",     // 5. Workspaces
        "custom/music"             // 6. Música
    ],
    "modules-center": [
        "hyprland/window"
    ],
    "modules-right": [
        "pulseaudio",
        "network",
        "battery",
        "cpu",
        "memory",
        "clock",
        "tray",
        "custom/power"
    ],

    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Modo: {profile}",
        "format-icons": {
            "default": "󱐋",
            "performance": "󰓅",
            "balanced": "󰾅",
            "power-saver": "󰌪"
        }
    },

    "custom/launcher": {
        "format": " EndeavourOS",
        "on-click": "wofi --show drun",
        "tooltip": false
    },

    "temperature": {
	"hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
	"critical-threshold": 80,
	"format": "{temperatureC}°C {icon}",
	"format-icons": ["", "", ""]
    },
    "custom/icon": {
        "format": "󰣇",
        "on-click": "kitty",
        "tooltip-format": "Abrir Terminal"
    },

    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "active": "󰮯",
            "default": "󰊠"
        }
    },

    "custom/music": {
        "format": "󰎆 {}",
        "interval": 2,
        "exec": "playerctl metadata --format '{{ title }}' 2>/dev/null || echo '󰏤 Descansando'",
        "on-click": "playerctl play-pause",
        "max-length": 20
    },

    "hyprland/window": {
        "format": "󰖲 {class}",
        "max-length": 40,
        "on-click": "hyprctl dispatch killactive",
        "separate-outputs": true
    },

    "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-icons": ["󰕿", "󰖀", "󰕾"],
        "on-click": "pavucontrol"
    },

    "network": {
        "format-wifi": " {essid}",
        "format-ethernet": "󰈀",
        "format-disconnected": "󰖪"
    },

    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "{capacity}% {icon}",
        "format-icons": ["", "", "", "", ""]
    },

    "cpu": { "format": "{usage}% 󰍲" },
    "memory": { "format": "{used:0.1f}GB 󰋙" },
    "clock": { "format": "{:%H:%M | 󰃏 %d-%m}", "on-click": "gsimplecal" },
    "tray": { "icon-size": 16, "spacing": 10 },
    "custom/power": { "format": "󰐥", "on-click": "wlogout", "tooltip": false }
}